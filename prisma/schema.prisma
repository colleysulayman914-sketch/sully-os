generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Todo {
  id             String    @id @default(cuid())
  title          String
  completed      Boolean   @default(false)
  status         String    @default("pending") // pending | cancel | completed | archived
  priority       String?   // low | medium | high
  dueDate        DateTime?
  repeatRule     String?   // none | daily | weekly | monthly | yearly | custom
  repeatInterval Int?      // used when repeatRule === "custom"
  repeatUnit     String?   // day | week | month, used when repeatRule === "custom"
  createdAt      DateTime  @default(now())
}

model Expense {
  id       String    @id @default(cuid())
  amountCents Int    // amount in cents (e.g. 1999 = $19.99)
  date     DateTime
  note     String?
  category String?   // Food | Transport | Bills | Shopping | Health | Giveaways | Parent Allowances | School Transportation | Other
  createdAt DateTime @default(now())
}
