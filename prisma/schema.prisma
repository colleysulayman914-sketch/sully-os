generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Todo {
  id             String    @id @default(cuid())
  title          String
  completed      Boolean   @default(false)
  status         String    @default("pending") // pending | cancel | completed | archived
  priority       String?   // low | medium | high
  dueDate        DateTime?
  repeatRule     String?   // none | daily | weekly | monthly | yearly | custom
  repeatInterval Int?      // used when repeatRule === "custom"
  repeatUnit     String?   // day | week | month, used when repeatRule === "custom"
  createdAt      DateTime  @default(now())
}

model Expense {
  id             String   @id @default(cuid())
  amountCents    Int      // amount in cents (e.g. 1999 = 19.99)
  date           DateTime
  note           String?
  category       String?  // Food | Transport | Bills | ...
  toWhom         String?  // who the money was given to
  paymentMethod  String?  // Mobile Money | Cash | Bank Transfer | Card | Other
  createdAt      DateTime @default(now())
}

model Earning {
  id             String   @id @default(cuid())
  amountCents    Int
  date           DateTime
  note           String?
  category       String?  // Salaries | Side Project | Friends & Family | Other
  fromWhom       String?  // who you received money from
  paymentMethod  String?  // same as Expense
  createdAt      DateTime @default(now())
}

model SavingsCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model SavingsDeposit {
  id          String   @id @default(cuid())
  amountCents Int
  date        DateTime
  note        String?
  category    String   // name from SavingsCategory
  createdAt   DateTime @default(now())
}

model SavingsGoal {
  id               String   @id @default(cuid())
  category         String   @unique // name from SavingsCategory
  targetAmountCents Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
